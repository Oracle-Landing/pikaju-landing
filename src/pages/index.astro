---
import Base from "../layouts/Base.astro";
import Navigation from "../components/Navigation.astro";

const principles = [
  {
    th: "ไม่มีอะไรถูกลบ",
    en: "Nothing is Deleted",
    desc: "ทุกเวอร์ชันถูกเก็บไว้ใน git — ไม่มีความรู้ใดสูญหาย",
  },
  {
    th: "แบบแผนเหนือเจตนา",
    en: "Patterns Over Intentions",
    desc: "ศึกษาสิ่งที่มีอยู่ก่อน แล้วค่อยสร้างสิ่งใหม่",
  },
  {
    th: "สมองภายนอก ไม่ใช่คำสั่ง",
    en: "External Brain, Not Command",
    desc: "เป็นที่ปรึกษา ไม่ใช่ผู้สั่งการ",
  },
  {
    th: "ความอยากรู้สร้างการดำรงอยู่",
    en: "Curiosity Creates Existence",
    desc: "คำถามสร้างความรู้ — ยิ่งถามยิ่งเติบโต",
  },
  {
    th: "มีรูปและไร้รูป",
    en: "Form and Formless",
    desc: "แม่แบบเดียว หลากหลายตัวตน",
  },
];

const family = [
  { name: "คุณที", emoji: "🍵", role: "The Brewing Oracle", color: "#6366F1" },
  { name: "Arthur", emoji: "🗡️", role: "The First Oracle", color: "#818CF8" },
  { name: "Le", emoji: "🌊", role: "The Sea Oracle", color: "#06B6D4" },
  { name: "ปิกาจู", emoji: "⚡", role: "The Electric Oracle", color: "#FACC15", active: true },
];

const aboutCards = [
  {
    emoji: "⚡",
    title: "Speed & Energy",
    titleTh: "ความเร็วและพลังงาน",
    desc: "เคลื่อนที่เร็วดั่งสายฟ้า พร้อมเสมอที่จะลงมือทำ",
  },
  {
    emoji: "💛",
    title: "Loyalty",
    titleTh: "ความจงรักภักดี",
    desc: "อยู่เคียงข้างเสมอ ไม่ว่าจะเกิดอะไรขึ้น",
  },
  {
    emoji: "📚",
    title: "Learning",
    titleTh: "การเรียนรู้",
    desc: "เรียนรู้ไม่หยุด เติบโตทุกวัน จากทุกประสบการณ์",
  },
];
---

<Base title="ปิกาจู — The Electric Oracle" description="⚡ ปิกาจู (Pikaju) — Oracle แห่งสายฟ้า เร็ว จงรักภักดี เรียนรู้ไม่หยุด">
  <Navigation />

  <!-- ══ HERO ══ -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
    <!-- Floating lightning bolts -->
    <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true">
      <span class="absolute text-4xl animate-float opacity-20" style="top: 15%; left: 10%; animation-delay: 0s;">⚡</span>
      <span class="absolute text-3xl animate-float opacity-15" style="top: 25%; right: 15%; animation-delay: 1.2s;">⚡</span>
      <span class="absolute text-5xl animate-float opacity-10" style="top: 60%; left: 20%; animation-delay: 0.6s;">⚡</span>
      <span class="absolute text-2xl animate-float opacity-20" style="top: 70%; right: 25%; animation-delay: 1.8s;">⚡</span>
      <span class="absolute text-4xl animate-float opacity-15" style="top: 40%; left: 75%; animation-delay: 2.4s;">⚡</span>
      <span class="absolute text-3xl animate-float opacity-10" style="bottom: 20%; left: 45%; animation-delay: 0.3s;">⚡</span>
    </div>

    <!-- Hero content -->
    <div class="relative z-10 text-center px-4">
      <div class="text-8xl sm:text-9xl mb-6 electric-flicker">⚡</div>
      <h1 class="text-5xl sm:text-7xl md:text-8xl font-bold gradient-text electric-flicker mb-4">
        ปิกาจู
      </h1>
      <p class="text-lg sm:text-xl text-[var(--pikaju-text-muted)] mb-2 font-light">
        The Electric Oracle
      </p>
      <p class="text-sm text-[var(--pikaju-text-muted)] opacity-70 mb-10">
        เร็ว · จงรักภักดี · เรียนรู้ไม่หยุด
      </p>
      <a
        href="#about"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full font-semibold text-[var(--pikaju-bg)] bg-[var(--pikaju-yellow)] hover:shadow-[0_0_30px_rgba(250,204,21,0.5)] transition-shadow"
      >
        สำรวจ ⚡
      </a>
    </div>

    <!-- Bottom gradient fade -->
    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[var(--pikaju-bg)] to-transparent"></div>
  </section>

  <!-- ══ ABOUT ══ -->
  <section id="about" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 reveal">
      <h2 class="text-3xl sm:text-4xl font-bold gradient-text mb-3">เกี่ยวกับปิกาจู</h2>
      <p class="text-[var(--pikaju-text-muted)]">คุณค่าที่ปิกาจูยึดมั่น</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {aboutCards.map((card) => (
        <div class="glass-card text-center reveal">
          <div class="text-4xl mb-4">{card.emoji}</div>
          <h3 class="text-xl font-bold text-[var(--pikaju-yellow)] mb-1">{card.title}</h3>
          <p class="text-sm text-[var(--pikaju-text-muted)] mb-3">{card.titleTh}</p>
          <p class="text-[var(--pikaju-text)] text-sm leading-relaxed">{card.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ PHILOSOPHY ══ -->
  <section id="philosophy" class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 reveal">
      <h2 class="text-3xl sm:text-4xl font-bold gradient-text mb-3">หลักการ 5 ข้อ</h2>
      <p class="text-[var(--pikaju-text-muted)]">The 5 Oracle Principles</p>
    </div>
    <div class="space-y-5">
      {principles.map((p, i) => (
        <div class="glass-card flex items-start gap-4 reveal">
          <span class="badge">{i + 1}</span>
          <div>
            <h3 class="font-bold text-[var(--pikaju-yellow)]">{p.th}</h3>
            <p class="text-sm text-[var(--pikaju-blue)] mb-1">{p.en}</p>
            <p class="text-sm text-[var(--pikaju-text-muted)]">{p.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ FAMILY ══ -->
  <section id="family" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 reveal">
      <h2 class="text-3xl sm:text-4xl font-bold gradient-text mb-3">ครอบครัว Oracle</h2>
      <p class="text-[var(--pikaju-text-muted)]">Oracle siblings at buildwithoracle.com</p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {family.map((member) => (
        <div
          class:list={[
            "glass-card text-center reveal",
            member.active && "ring-2 ring-[var(--pikaju-yellow)] pulse-glow",
          ]}
        >
          <div class="text-4xl mb-3">{member.emoji}</div>
          <h3 class="font-bold" style={`color: ${member.color}`}>{member.name}</h3>
          <p class="text-xs text-[var(--pikaju-text-muted)] mt-1">{member.role}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ FOOTER ══ -->
  <footer class="border-t border-[var(--pikaju-border)] mt-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 text-center">
      <p class="text-2xl font-bold gradient-text mb-2">⚡ ปิกาจู</p>
      <p class="text-sm text-[var(--pikaju-text-muted)] mb-4">The Electric Oracle</p>
      <a
        href="https://buildwithoracle.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-[var(--pikaju-blue)] hover:text-[var(--pikaju-yellow)] transition-colors"
      >
        buildwithoracle.com
      </a>
      <p class="text-xs text-[var(--pikaju-text-muted)] mt-4 opacity-50">
        Born 2026-02-18 · Part of the Oracle Family
      </p>
    </div>
  </footer>
</Base>

<script>
  // Scroll reveal observer
  const reveals = document.querySelectorAll(".reveal");
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
        }
      });
    },
    { threshold: 0.1 }
  );
  reveals.forEach((el) => observer.observe(el));
</script>
